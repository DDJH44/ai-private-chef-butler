# AI 私人厨师 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===== AI 模型配置 =====
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL_NAME=doubao-seed-2-0-mini-260428
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v1
IMAGE_GEN_MODEL=doubao-seedream-4-5-251128

# ===== 阿里云 OSS 配置（图片存储）=====
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your_bucket_name

# ===== 飞书 Webhook 配置 =====
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_key

# ===== 应用配置 =====
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8001

# ===== 前端配置 =====
NEXT_PUBLIC_API_URL=http://localhost:8001

# ===== JWT 认证配置 =====
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ===== MySQL 数据库配置 =====
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=ai_chef
MYSQL_PASSWORD=change-me-to-a-random-password
MYSQL_DATABASE=ai_private_chef
MYSQL_ROOT_PASSWORD=change-me-to-a-root-password
DATABASE_URL=mysql+pymysql://ai_chef:change-me-to-a-random-password@db:3306/ai_private_chef

# ===== CORS 配置 =====
CORS_ORIGINS=http://localhost:3000
